# Copy this file to `.env.local` and fill values as needed.

# Adzuna provider (optional)
# Keep disabled by default. Forem remains the primary source.
ADZUNA_ENABLED=false
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Country code used by Adzuna API endpoint (default: be)
ADZUNA_COUNTRY=be

# Umami analytics (optional)
# Disabled by default. Enable only if you want tracking.
UMAMI_ENABLED=false
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Allowed script hosts are restricted in code for safety.
# Supported values today: https://cloud.umami.is/script.js and https://stats.brisbois.dev/script.js
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# PostgreSQL / auth sync (optional but recommended for multi-device accounts)
# In Coolify with a private internal Postgres service, keep SSL disabled.
# Use DB_SSL_MODE=require only for an external database with a valid certificate chain.
DATABASE_URL=
DB_SSL_MODE=disable
DB_SSL_CA_PEM=
DB_SSL_CA_BASE64=

# Redis rate limiting (recommended for multi-instance deployments)
REDIS_URL=
# Optional structured timing logs for DB / Redis / in-memory fallback.
SERVER_TIMING_LOGS=false
# Optional structured event logs for auth/security/admin/coach audit-style events.
SERVER_AUDIT_LOGS=true
# HMAC secret used to hash userIds in operational logs (RGPD anonymisation).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_HASH_SECRET=change-me-in-production
# Threshold in milliseconds for slow Postgres queries when timing logs are enabled.
DB_SLOW_QUERY_MS=200

# Data retention periods (in days / months).
# Sessions, password-reset tokens, search history, and data exports use days.
# Message content and audit logs use months.
PASSWORD_RESET_RETENTION_DAYS=7
SEARCH_HISTORY_RETENTION_DAYS=365
DATA_EXPORT_RETENTION_DAYS=7
MESSAGE_RETENTION_MONTHS=18
AUDIT_LOG_RETENTION_MONTHS=24
# Password reset by email (Resend)
PASSWORD_RESET_ENABLED=false
NEXT_PUBLIC_PASSWORD_RESET_ENABLED=false
# Public browser-facing app origin used by origin/CSRF checks.
APP_BASE_URL=http://localhost:3000
# Core app branding.
# `APP_NAME` is the single source of truth for the visible product name.
APP_NAME=FOREM-idable
# Full browser title. Override this if you do not want the default `<APP_NAME> - <APP_TITLE_SUFFIX>`.
APP_TITLE=FOREM-idable - Indexeur d'offres
# Suffix used when `APP_TITLE` is not set.
APP_TITLE_SUFFIX=Indexeur d'offres
APP_META_DESCRIPTION=Recherche d'offres d'emploi du Forem, simplifiée et décomplexée.
APP_TAGLINE=L'indexeur d'offres décomplexé
APP_SOURCE_LINK_LABEL=Code source AGPLv3
# Technical identifiers. Usually keep them aligned with the app name.
# Only override them if you need stable filenames or storage keys during a rename.
# Slug used for exported filenames and calendar downloads.
APP_EXPORT_FILENAME_PREFIX=forem-idable
# Namespace used for localStorage keys / browser events.
APP_STORAGE_NAMESPACE=forem_idable
# Optional override for auth session cookie name.
APP_SESSION_COOKIE_NAME=forem_idable_session
# Optional domain-like suffix used inside ICS UIDs.
APP_CALENDAR_UID_DOMAIN=forem-idable
RESEND_API_KEY=
RESEND_FROM_EMAIL=FOREM-idable <no-reply@example.com>
RESEND_REPLY_TO=RGPD@brisbois.dev

# Privacy page customization
PRIVACY_CONTROLLER_NAME=Jordi Brisbois
PRIVACY_CONTACT_EMAIL=RGPD@brisbois.dev
PRIVACY_SOURCE_URL=https://github.com/VoxSake/FOREM-idable
PRIVACY_LAST_UPDATED_LABEL=25 mars 2026
COPYRIGHT_NAME=Jordi Brisbois
