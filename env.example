# Copy this file to `.env.local` and fill values as needed.

# Adzuna provider (optional)
# Keep disabled by default. Forem remains the primary source.
ADZUNA_ENABLED=false
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Country code used by Adzuna API endpoint (default: be)
ADZUNA_COUNTRY=be

# Umami analytics (optional)
# Disabled by default. Enable only if you want tracking.
UMAMI_ENABLED=false
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Allowed script hosts are restricted in code for safety.
# Supported values today: https://cloud.umami.is/script.js and https://stats.brisbois.dev/script.js
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# PostgreSQL / auth sync (optional but recommended for multi-device accounts)
DATABASE_URL=

# Password reset by email (Resend)
PASSWORD_RESET_ENABLED=false
NEXT_PUBLIC_PASSWORD_RESET_ENABLED=false
APP_BASE_URL=http://localhost:3000
RESEND_API_KEY=
RESEND_FROM_EMAIL=FOREM-idable <no-reply@example.com>
RESEND_REPLY_TO=RGPD@brisbois.dev

# Privacy page customization
PRIVACY_CONTROLLER_NAME=Jordi Brisbois
PRIVACY_CONTACT_EMAIL=RGPD@brisbois.dev
PRIVACY_PROJECT_LABEL=FOREM-idable
PRIVACY_SOURCE_URL=https://github.com/VoxSake/FOREM-idable
COPYRIGHT_NAME=Jordi Brisbois
